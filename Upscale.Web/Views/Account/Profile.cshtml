@* View: Profile
    Model: ProfileViewModel
    Purpose: Displays user identity and employment data. 
    Allows users to update their contact information (Emails and Phones).
*@

@model Upscale.Web.Models.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "Perfil de usuario";
}

<div class="profile-page">

    <nav class="profile-breadcrumb" aria-label="breadcrumb">
        <span>Perfil de usuario</span>
    </nav>

    <h1 class="profile-heading">Perfil de usuario</h1>

    @if (TempData["ProfileSuccess"] != null)
    {
        <div class="profile-alert profile-alert--success" role="alert">
            <i class="fa-solid fa-circle-check"></i>
            @TempData["ProfileSuccess"]
        </div>
    }

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="profile-alert profile-alert--error" role="alert">
            <i class="fa-solid fa-circle-exclamation"></i>
            Por favor, revisa los campos marcados antes de guardar.
        </div>
    }

    <form asp-controller="Account" asp-action="Profile" method="post" novalidate>
        @Html.AntiForgeryToken()

        <div class="profile-card">

            <div class="profile-card-header">
                <div class="profile-avatar">
                    <i class="fa-solid fa-user" aria-hidden="true"></i>
                </div>
                <div class="profile-identity">
                    <div class="profile-fullname-row">
                        <span class="profile-fullname">@Model.FullName</span>
                        <span class="profile-status-badge @(Model.IsActive ? "badge-active" : "badge-inactive")">
                            @Model.StatusLabel
                        </span>
                    </div>
                    <div class="profile-jobtitle">@Model.JobTitle</div>
                    <div class="profile-org">@Model.Organization</div>
                </div>
            </div>

            <div class="profile-tabs" role="tablist">
                <button type="button" class="profile-tab active" data-tab="basic" role="tab">Información básica</button>
                <button type="button" class="profile-tab" data-tab="responsibilities" role="tab">Responsabilidades</button>
                <button type="button" class="profile-tab" data-tab="history" role="tab">Historial de responsabilidades</button>
            </div>

            <div class="profile-tab-content active" id="tab-basic" role="tabpanel">
                <div class="profile-fields-grid">

                    @* Read-only Identity Fields *@
                    <div class="field-group">
                        <label class="field-label">Nombres</label>
                        <div class="field-value">@Model.FirstName</div>
                    </div>

                    <div class="field-group">
                        <label class="field-label">Primer Apellido</label>
                        <div class="field-value">@Model.FirstLastName</div>
                    </div>

                    <div class="field-group">
                        <label class="field-label">Segundo Apellido</label>
                        <div class="field-value">@Model.SecondLastName</div>
                    </div>

                    <div class="field-group">
                        <label class="field-label">Tipo de Documento</label>
                        <div class="field-value">@Model.DocumentType</div>
                    </div>

                    <div class="field-group">
                        <label class="field-label">N° de Documento</label>
                        <div class="field-value">@Model.DocumentNumber</div>
                    </div>

                    <div class="field-group">
                        <label class="field-label">Fecha de nacimiento</label>
                        <div class="field-value">@Model.BirthDateFormatted</div>
                    </div>

                    <div class="field-group">
                        <label class="field-label">Nacionalidad</label>
                        <div class="field-value">@Model.Nationality</div>
                    </div>

                    <div class="field-group">
                        <label class="field-label">Sexo</label>
                        <div class="field-value">@Model.Gender</div>
                    </div>

                    @* Editable Contact Fields *@
                    <div class="field-group @(ViewData.ModelState["Email"]?.Errors.Count > 0 ? "field-group--error" : "")">
                        <label class="field-label" asp-for="Email">Correo electrónico principal</label>
                        <div class="field-value field-input-wrap">
                            <input asp-for="Email" type="email" class="field-input" placeholder="correo@ejemplo.pe" />
                        </div>
                        <span asp-validation-for="Email" class="field-error-msg"></span>
                    </div>

                    <div class="field-group @(ViewData.ModelState["SecondaryEmail"]?.Errors.Count > 0 ? "field-group--error" : "")">
                        <label class="field-label" asp-for="SecondaryEmail">
                            Correo electrónico secundario
                            <span class="field-optional">(Opcional)</span>
                        </label>
                        <div class="field-value field-input-wrap">
                            <input asp-for="SecondaryEmail" type="email" class="field-input" />
                        </div>
                        <span asp-validation-for="SecondaryEmail" class="field-error-msg"></span>
                    </div>

                    <div class="field-group @(ViewData.ModelState["MobilePhone"]?.Errors.Count > 0 ? "field-group--error" : "")">
                        <label class="field-label" asp-for="MobilePhone">Teléfono Móvil</label>
                        <div class="field-value field-input-wrap">
                            <input asp-for="MobilePhone" type="tel" class="field-input" placeholder="+51 999 999 999" />
                        </div>
                        <span asp-validation-for="MobilePhone" class="field-error-msg"></span>
                    </div>

                    <div class="field-group @(ViewData.ModelState["SecondaryPhone"]?.Errors.Count > 0 ? "field-group--error" : "")">
                        <label class="field-label" asp-for="SecondaryPhone">
                            Teléfono secundario
                            <span class="field-optional">(Opcional)</span>
                        </label>
                        <div class="field-value field-input-wrap">
                            <input asp-for="SecondaryPhone" type="tel" class="field-input" />
                        </div>
                        <span asp-validation-for="SecondaryPhone" class="field-error-msg"></span>
                    </div>

                    @* Read-only Employment Fields *@
                    <div class="field-group">
                        <label class="field-label">Tipo de Contratación</label>
                        <div class="field-value">@Model.ContractType</div>
                    </div>

                    <div class="field-group">
                        <label class="field-label">Fecha de contratación</label>
                        <div class="field-value">@Model.HireDateFormatted</div>
                    </div>

                </div>

                <div class="profile-save-row">
                    <button type="submit" class="btn-save">
                        <i class="fa-solid fa-floppy-disk" aria-hidden="true"></i>
                        Guardar datos
                    </button>
                </div>

            </div>

            <div class="profile-tab-content" id="tab-responsibilities" role="tabpanel">
                <div class="tab-empty-state">
                    <i class="fa-solid fa-briefcase tab-empty-icon" aria-hidden="true"></i>
                    <p class="tab-empty-text">Sin actividad</p>
                </div>
            </div>

            <div class="profile-tab-content" id="tab-history" role="tabpanel">
                <div class="tab-empty-state">
                    <i class="fa-solid fa-clock-rotate-left tab-empty-icon" aria-hidden="true"></i>
                    <p class="tab-empty-text">Sin actividad</p>
                </div>
            </div>

        </div>
    </form>
</div>

<footer class="footer-ceplan profile-footer">
    <img src="~/images/logos-footer.png" alt="Logos institucionales" class="footer-logos" />
</footer>

@section Scripts {
    <script>
        /**
         * Profile Page UI Logic
         * Handles tab switching and automatic alert dismissal.
         */
        (function () {
            // Tab Switcher Initialization
            const tabs = document.querySelectorAll('.profile-tab');
            const panels = document.querySelectorAll('.profile-tab-content');

            tabs.forEach(function (tab) {
                tab.addEventListener('click', function () {
                    const target = tab.dataset.tab;
                    
                    // Reset active states
                    tabs.forEach(t => t.classList.remove('active'));
                    panels.forEach(p => p.classList.remove('active'));
                    
                    // Set current active state
                    tab.classList.add('active');
                    const targetPanel = document.getElementById('tab-' + target);
                    if (targetPanel) targetPanel.classList.add('active');
                });
            });

            // Auto-dismiss Alerts after 4 seconds
            document.querySelectorAll('.profile-alert').forEach(function (el) {
                setTimeout(function () {
                    el.style.transition = 'opacity 0.4s ease';
                    el.style.opacity = '0';
                    setTimeout(() => el.remove(), 400);
                }, 4000);
            });
        })();
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}