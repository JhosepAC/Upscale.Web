<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CEPLAN</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
</head>
<body class="@(User.Identity.IsAuthenticated ? "dashboard-body" : "auth-body")">

    @if (User.Identity.IsAuthenticated)
    {
        <div class="dashboard-wrapper">

            <aside class="sidebar" id="sidebar">
                <button class="toggle-btn" id="toggleBtn" title="Expandir/Colapsar menú" aria-label="Alternar menú">
                    <i class="fa-solid fa-chevron-left" id="toggleIcon"></i>
                </button>

                <div class="sidebar-header">
                    <div class="logo-container">
                        <img src="~/images/logo-ceplan.png" alt="CEPLAN" class="logo-img" />
                    </div>
                </div>

                <nav class="sidebar-nav flex-grow-1">
                    <div class="nav-section">MENÚ</div>

                    <a asp-controller="Home" asp-action="Index"
                           class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
                           title="Inicio">
                        <i class="fa-solid fa-house"></i>
                        <span>Inicio</span>
                    </a>

                    <a asp-controller="Users" asp-action="Index"
                           class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Users" ? "active" : "")"
                           title="Gestión de usuarios">
                        <i class="fa-solid fa-users"></i>
                        <span>Gestión de usuarios</span>
                    </a>

                    <a asp-controller="Reports" asp-action="Index"
                           class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reports" ? "active" : "")"
                           title="Reportes">
                        <i class="fa-solid fa-chart-bar"></i>
                        <span>Reportes</span>
                    </a>

                    <a asp-controller="Search" asp-action="Index"
                           class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Search" ? "active" : "")"
                           title="Búsqueda">
                        <i class="fa-solid fa-magnifying-glass"></i>
                        <span>Búsqueda</span>
                    </a>
                </nav>

                <div class="sidebar-footer">
                    <form asp-controller="Account" asp-action="Logout" method="post" id="logoutForm">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="nav-item logout-item w-100 border-0 bg-transparent text-start" title="Cerrar sesión">
                            <i class="fa-solid fa-right-from-bracket"></i>
                            <span>Cerrar sesión</span>
                        </button>
                    </form>
                </div>
            </aside>

            <div class="main-area">

                <header class="top-navbar">
                    <div class="top-navbar-right">
                        <button class="icon-btn" title="Ayuda" aria-label="Ayuda">
                            <i class="fa-solid fa-circle-question"></i>
                        </button>

                        <button class="icon-btn notification-btn" title="Notificaciones" aria-label="Notificaciones">
                            <i class="fa-solid fa-bell"></i>
                            <span class="notification-badge">9+</span>
                        </button>

                        <a asp-controller="Account" asp-action="Profile" class="user-profile-link" title="Ver perfil">
                            <div class="user-info text-end">
                                <div class="user-name">@User.Identity.Name</div>
                                <div class="user-role">Cargo del Usuario</div>
                            </div>
                            <div class="user-avatar">
                                <i class="fa-solid fa-circle-user"></i>
                            </div>
                        </a>
                    </div>
                </header>

                <main class="main-content">
                    @RenderBody()
                </main>

            </div>
        </div>

        <div id="sessionOverlay"
             class="session-overlay"
             role="dialog"
             aria-hidden="true"
             aria-labelledby="sessionModalTitle"
             aria-modal="true">
            <div class="session-modal">

                <div class="session-modal__icon">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                </div>

                <div class="session-modal__body">
                    <p class="session-modal__title" id="sessionModalTitle">
                        Su sesión esta a punto de expirar
                    </p>
                    <p class="session-modal__desc">
                        Por seguridad, su sesión expirará en
                        <span id="sessionCountdown">60</span> segundos.
                        Para continuar, seleccione "Extender sesión"
                    </p>
                </div>

                <div class="session-modal__actions">
                    <button type="button" id="btnExtendSession" class="btn-extend-session">
                        Extender sesión
                    </button>
                </div>

            </div>
        </div>
    }
    else
    {
        <div class="auth-wrapper">
            <header class="header-ceplan">
                <div class="ms-auto">
                    <i class="fa-solid fa-circle-question text-white fs-5 cursor-pointer" title="Ayuda"></i>
                </div>
            </header>

            <main class="auth-main">
                @RenderBody()
            </main>

            <footer class="footer-ceplan">
                <img src="~/images/logos-footer.png" alt="Logos" class="footer-logos" />
            </footer>
        </div>
    }

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @if (User.Identity.IsAuthenticated)
    {
        <script>
                (function () {
                    const sidebar    = document.getElementById('sidebar');
                    const toggleBtn  = document.getElementById('toggleBtn');
                    const toggleIcon = document.getElementById('toggleIcon');
                    const KEY        = 'sidebar_collapsed';

                    if (localStorage.getItem(KEY) === 'true') {
                        sidebar.classList.add('collapsed');
                        toggleIcon.classList.replace('fa-chevron-left', 'fa-chevron-right');
                    }

                    toggleBtn.addEventListener('click', function () {
                        const collapsed = sidebar.classList.toggle('collapsed');
                        localStorage.setItem(KEY, collapsed);
                        toggleIcon.classList.replace(
                            collapsed ? 'fa-chevron-left'  : 'fa-chevron-right',
                            collapsed ? 'fa-chevron-right' : 'fa-chevron-left'
                        );
                    });
                })();

                (function () {

                    const IDLE_TIMEOUT_MS  = 60 * 1000;
                    const WARN_COUNTDOWN_S = 60;

                    const overlay    = document.getElementById('sessionOverlay');
                    const countdownEl = document.getElementById('sessionCountdown');
                    const btnExtend  = document.getElementById('btnExtendSession');
                    const logoutForm = document.getElementById('logoutForm');

                    let idleTimer    = null;
                    let warnInterval = null;
                    let modalOpen    = false;

                    function openModal() {
                        if (modalOpen) return;
                        modalOpen = true;

                        let remaining = WARN_COUNTDOWN_S;
                        countdownEl.textContent = remaining;

                        overlay.classList.add('session-overlay--visible');
                        overlay.setAttribute('aria-hidden', 'false');
                        btnExtend.focus();

                        warnInterval = setInterval(function () {
                            remaining -= 1;
                            countdownEl.textContent = remaining;

                            if (remaining <= 0) {
                                clearInterval(warnInterval);
                                logoutForm.submit();
                            }
                        }, 1000);
                    }

                    function closeModalAndExtend() {
                        if (!modalOpen) return;
                        modalOpen = false;

                        clearInterval(warnInterval);
                        overlay.classList.remove('session-overlay--visible');
                        overlay.setAttribute('aria-hidden', 'true');

                        var token = (document.querySelector('input[name="__RequestVerificationToken"]') || {}).value || '';
                        fetch('/Account/ExtendSession', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/x-www-form-urlencoded',
                                'X-Requested-With': 'XMLHttpRequest',
                                'RequestVerificationToken': token
                            }
                        }).catch(function () { });
                    }

                    function resetIdleTimer() {
                        if (modalOpen) return;
                        clearTimeout(idleTimer);
                        idleTimer = setTimeout(openModal, IDLE_TIMEOUT_MS);
                    }

                    ['mousemove', 'mousedown', 'keydown', 'scroll', 'touchstart', 'click']
                        .forEach(function (evt) {
                            document.addEventListener(evt, resetIdleTimer, { passive: true });
                        });

                    btnExtend.addEventListener('click', function () {
                        closeModalAndExtend();
                        resetIdleTimer();
                    });

                    resetIdleTimer();

                })();
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
